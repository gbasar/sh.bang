#!/usr/bin/env bash
# Debug scenario runners for the playground environment.
# Called by bin/playground --debug-replay / --debug-replay-intellij.
# Requires: SSH config and JAVA_HOME already set (source bin/playground first).

set -euo pipefail

REPO="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
SSH_CONFIG="$REPO/.playground-ssh-config"
SSH_KEY="$REPO/tests/e2e/e2e_test_key"

declare -A _SHARD_PORTS=(
  [shard_1]="1 5005 5005"
  [shard_2]="1 5006 5006"
  [shard_3]="2 5005 5007"
  [shard_4]="2 5006 5008"
)

declare -A _CMDS=(
  [debug-replay]=debug_replay
  [debug-replay-intellij]=debug_replay_intellij
)

_reset_debug_fixtures() {
  local shard=$1 host_idx=$2 port=$3
  local host="trading-host${host_idx}"
  local pidfile="/tmp/bluebird-${shard}.pid"
  echo "[playground] tearing down $shard on $host..."
  ssh -F "$SSH_CONFIG" "$host" \
    "[ -f ${pidfile} ] && kill -9 \$(cat ${pidfile}) 2>/dev/null; sleep 1; rm -f ${pidfile}; rm -rf /opt/trading/${shard}; true"
  echo "[playground] installing fresh debug fixtures (jdwp=$port)..."
  export E2E_SSH_KEY="$SSH_KEY"
  export E2E_SSH_CONFIG="$SSH_CONFIG"
  source "$REPO/tests/lib/bbStruct.sh"
  local BLACKBIRD_JAR="$REPO/tools/bluebird-stub/bluebird-stub.jar"
  [[ -f $BLACKBIRD_JAR ]] || { echo "ERROR: bluebird-stub.jar not found — run: docker compose build e2e" >&2; exit 1; }
  bb_create_shard_layout   "$host" /opt/trading "$shard"
  bb_create_debug_binaries "$host" /opt/trading "$shard" "$BLACKBIRD_JAR" "$port"
  bb_create_rdat           "$host" /opt/trading "$shard" \
                           "$REPO/tests/e2e/fixtures/debug-replay/trading.rdat.in" \
                           "$REPO/tests/e2e/fixtures/debug-replay/trading.rdat.out"
}

_shard_ports() {
  local shard=$1
  local entry=${_SHARD_PORTS[$shard]:-}
  [[ -n $entry ]] || { echo "[playground] unknown shard: $shard" >&2; return 1; }
  echo "$entry"
}

debug_replay() {
  local shard="${1:-shard_1}" class="${2:-com.bluebird.trading.OrderEventHandler}"
  local method="${3:-process}" condition="${4:-orderId=ORD-12345}"
  local traceFilter="${5:-com.bluebird.trading.*}" traceLimit="${6:-500}"

  local host_idx container_port host_port
  read -r host_idx container_port host_port <<< "$(_shard_ports "$shard")"
  local host="trading-host${host_idx}"

  echo "[playground] debug-replay (trace): $shard  jdwp=localhost:${host_port}"
  _reset_debug_fixtures "$shard" "$host_idx" "$container_port"

  ssh -F "$SSH_CONFIG" -i "$SSH_KEY" \
      -o StrictHostKeyChecking=no -o BatchMode=yes -o KexAlgorithms=ecdh-sha2-nistp256 \
      "deploy@${host}" \
      "setsid nohup /opt/trading/${shard}/trading/app/trading/bin/start \
         > /tmp/bluebird-${shard}.log 2>&1 </dev/null & echo \$! > /tmp/bluebird-${shard}.pid"

  local i=0
  printf "[playground] waiting for JDWP on %s:%s..." "$host" "$container_port"
  until ssh -F "$SSH_CONFIG" -i "$SSH_KEY" \
            -o StrictHostKeyChecking=no -o BatchMode=yes -o KexAlgorithms=ecdh-sha2-nistp256 \
            "deploy@${host}" \
            "ss -tlnp 2>/dev/null | grep -q ':${container_port} '" 2>/dev/null; do
    sleep 0.5; i=$(( i + 1 ))
    (( i > 20 )) && { echo " timeout"; return 1; }
    printf '.'
  done
  echo " ready"

  echo "[playground] attaching jdi-attacher (--trace-after-hit)..."
  java --add-modules jdk.jdi -jar "$REPO/tools/jdi-attacher/jdi-attacher.jar" \
    localhost --port "$host_port" \
    --class "$class" --method "$method" --condition "$condition" \
    --trace-after-hit --trace-filter "$traceFilter" --trace-limit "$traceLimit"
}

debug_replay_intellij() {
  local shard="${1:-shard_1}" class="${2:-com.bluebird.trading.OrderEventHandler}"
  local method="${3:-process}" condition="${4:-orderId=ORD-12345}"

  local host_idx container_port host_port
  read -r host_idx container_port host_port <<< "$(_shard_ports "$shard")"
  local host="trading-host${host_idx}"

  echo "[playground] debug-replay (IntelliJ): $shard  jdwp=localhost:${host_port}"
  _reset_debug_fixtures "$shard" "$host_idx" "$container_port"

  ssh -F "$SSH_CONFIG" -i "$SSH_KEY" \
      -o StrictHostKeyChecking=no -o BatchMode=yes -o KexAlgorithms=ecdh-sha2-nistp256 \
      "deploy@${host}" \
      "setsid nohup /opt/trading/${shard}/trading/app/trading/bin/start \
         > /tmp/bluebird-${shard}.log 2>&1 </dev/null & echo \$! > /tmp/bluebird-${shard}.pid"

  echo
  echo "[playground] JVM frozen on localhost:${host_port} (suspend=y) — connect IntelliJ now:"
  echo "  Run > Edit Configurations > + > Remote JVM Debug"
  echo "  Host: localhost   Port: $host_port"
  echo "  Set conditional breakpoint:  Class=$class  Method=$method"
  echo "  Condition: orderId.equals(\"$(echo "$condition" | cut -d= -f2-)\")"
  echo "  Press Resume — JVM replays rdat.in; IntelliJ catches the hit."
  echo
}

cmd=${1:-}
shift || true
fn=${_CMDS[$cmd]:-}
if [[ -z $fn ]]; then
  echo "Usage: bin/playground-debug <debug-replay|debug-replay-intellij> [args...]" >&2
  exit 1
fi
"$fn" "$@"
