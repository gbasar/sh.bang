#!/usr/bin/env bash
set -euo pipefail

readonly SHBANG_VERSION="0.1.0"
readonly SHBANG_HOME="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
readonly SHBANG_CLI_SPEC="$SHBANG_HOME/spec/cli.json"

source "$SHBANG_HOME/lib/log.sh"
source "$SHBANG_HOME/lib/console.sh"
source "$SHBANG_HOME/lib/events.sh"
source "$SHBANG_HOME/lib/parser.sh"
source "$SHBANG_HOME/lib/router.sh"
source "$SHBANG_HOME/lib/expand.sh"
source "$SHBANG_HOME/lib/dispatch.sh"
source "$SHBANG_HOME/lib/ctx.sh"

declare -A SHBANG_COMMANDS=(
  [run]=cmd_run
)

_print_bang() {
  printf '\e[1;32m' >&2
  printf ' ___ _  _     ___   _   _  _  ___ _ \n' >&2
  printf '/ __| || |   | _ ) /_\ | \| |/ __| |\n' >&2
  printf '\__ \ __ |   | _ \/ _ \| .` | (_ |_|\n' >&2
  printf '|___/_||_|   |___/_/ \_|_|\_|\___|(_)\n' >&2
  printf '\e[0m\n' >&2
}

_print_boom() {
  printf '\e[1;31m' >&2
  if (( RANDOM % 2 )); then
    #claude make this sh.boom
    #claude move all banners to formatting lib
    printf ' ___ _  _ _ _____   ___  ___   ___  __  __ \n' >&2
    printf '/ __| || / |_   _| | _ )/ _ \ / _ \|  \/  |\n' >&2
    printf '\__ \ __ | | | |   | _ \ (_) | (_) | |\/| |\n' >&2
    printf '|___/_||_|_| |_|   |___/\___/ \___/|_|  |_|\n' >&2
  else
    #claude remove this
    printf ' _   _ _____  _____   ____  _____ _____ _   _   ____    _    ____  _   _ _____ ____  _ \n' >&2
    printf '| | | |/ _ \ | ____| | __ )| ____| ____| \ | | | __ )  / \  / ___|| | | | ____|  _ \| |\n' >&2
    printf '| |_| | | | ||  _|   |  _ \|  _| |  _| |  \| | |  _ \ / _ \ \___ \| |_| |  _| | | | |_|\n' >&2
    printf '|  _  | |_| || |___  | |_) | |___| |___| |\  | | |_) / ___ \ ___) |  _  | |___| |_| |_ \n' >&2
    printf '|_| |_|\___/ |_____| |____/|_____|_____|_| \_| |____/_/   \_\____/|_| |_|_____|____/(_)\n' >&2
  fi
  #Claude: this s/b in formatting libs
  printf '\e[0m\n' >&2
}

main() {
  runtime_init
  if route_cli "$@"; then
    _print_bang
  else
    _print_boom
    exit 1
  fi
}

runtime_init() {
  declare -gA SHBANG_RT=(
    [verbosity]=0
    [dry_run]=false
    [display]=ascii
    [version]="$SHBANG_VERSION"
    [home]="$SHBANG_HOME"
    [cli_spec]="$SHBANG_CLI_SPEC"
    [event_handlers]="console expand dispatch"
    [event_file]=""
  )
}

cmd_run() {
  local -A opts
  parse_run_args opts "$@"

  local ctx_json _ctx_tmp=
  # resolve_ctx may call die() in a subshell; $() masks the exit code — check explicitly
  ctx_json=$(resolve_ctx "${opts[ctx]}") || exit $?
  [[ $ctx_json != "${opts[ctx]}" ]] && _ctx_tmp=$ctx_json

  SHBANG_RT[ctx]="$ctx_json"
  SHBANG_RT[playbook_dir]="$(cd "$(dirname "${opts[playbook]}")" && pwd)"
  _CMD_QUEUE=()

  emit_kv run.loaded \
    playbook "${opts[playbook]}" \
    ctx "${opts[ctx]}"

  log_debug "bash: ${BASH_VERSION}"
  parse_playbook "${opts[playbook]}"
  dispatch_queue

  if [[ -n $_ctx_tmp ]]; then rm -f "$_ctx_tmp"; fi
}

main "$@"
