#!/usr/bin/env bash
# Start target1/target2 SSH servers and configure the local environment so
# you can run sh.bang and ssh directly from your host shell.
#
# Usage:
#   source bin/playground          # sets env vars in your shell
#   bin/playground --stop          # tear down containers
#   bin/playground --status        # show container state

# Only apply strict mode when executed as a script, not when sourced.
# Sourcing with set -e would kill the user's terminal on any error.
[[ "${BASH_SOURCE[0]}" != "${0}" ]] || set -euo pipefail

REPO="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
SSH_CONFIG="$REPO/.playground-ssh-config"
SSH_KEY="$REPO/tests/e2e/e2e_test_key"

_stop() {
  echo "[playground] stopping containers..."
  docker compose -f "$REPO/docker-compose.yml" stop target1 target2
  docker compose -f "$REPO/docker-compose.yml" rm -f target1 target2
  rm -f "$SSH_CONFIG"
  echo "[playground] done."
}

_status() {
  docker compose -f "$REPO/docker-compose.yml" ps target1 target2
}

_wait_for_ssh() {
  local host=$1 port=$2
  local i=0
  printf "[playground] waiting for %s..." "$host"
  while ! ssh -o StrictHostKeyChecking=no -o BatchMode=yes \
              -o ConnectTimeout=2 -i "$SSH_KEY" \
              -p "$port" deploy@localhost true 2>/dev/null; do
    sleep 1
    i=$(( i + 1 ))
    if (( i > 30 )); then
      echo " timeout"
      return 1
    fi
    printf '.'
  done
  echo " ready"
}

_debug_replay() {
  local shard="${1:-shard_1}"
  local port class method condition
  case "$shard" in
    shard_1) port=5005 ;; shard_2) port=5006 ;;
    shard_3) port=5007 ;; shard_4) port=5008 ;;
    *) echo "[playground] unknown shard: $shard"; exit 1 ;;
  esac
  class="${2:-OrderEventHandler}"
  method="${3:-process}"
  condition="${4:-orderId=ORD-12345}"

  # resolve host index from shard number
  local host_idx=$(( ${shard: -1} <= 2 ? 1 : 2 ))

  echo "[playground] debug-replay: $shard  jdwp=localhost:${port}"

  # set up debug fixtures if not already done
  local jar_remote="/opt/trading/${shard}/trading/app/trading/lib/bluebird-stub.jar"
  if ! ssh -F "$SSH_CONFIG" "trading-host${host_idx}" "test -f ${jar_remote}" 2>/dev/null; then
    echo "[playground] debug fixtures not found — running setup..."
    source "$REPO/tests/lib/bbStruct.sh"
    local BLACKBIRD_JAR="$REPO/tools/bluebird-stub/bluebird-stub.jar"
    [[ -f $BLACKBIRD_JAR ]] || { echo "ERROR: bluebird-stub.jar not found — run: docker compose build e2e" >&2; exit 1; }
    bb_create_shard_layout   "trading-host${host_idx}" /opt/trading "$shard"
    bb_create_debug_binaries "trading-host${host_idx}" /opt/trading "$shard" "$BLACKBIRD_JAR" "$port"
    bb_create_rdat           "trading-host${host_idx}" /opt/trading "$shard" \
                             "$REPO/tests/e2e/fixtures/debug-replay/trading.rdat.in" \
                             "$REPO/tests/e2e/fixtures/debug-replay/trading.rdat.out"
  fi

  echo "[playground] starting app on $shard..."
  ssh -F "$SSH_CONFIG" "trading-host${host_idx}" \
    "kill \$(cat /proc/*/cmdline 2>/dev/null | tr '\0' ' ' | grep -l bluebird-stub | sed 's|/proc/||;s|/.*||' | head -1) 2>/dev/null; true
     nohup /opt/trading/${shard}/trading/app/trading/bin/start \
       > /tmp/bluebird-${shard}.log 2>&1 &"

  echo "[playground] attaching jdi-attacher..."
  echo "[playground]   --class $class --method $method --condition $condition --hand-off"
  echo "[playground]   on hit: attach IntelliJ to localhost:${port}"
  echo
  java --add-modules jdk.jdi -jar "$REPO/tools/jdi-attacher/jdi-attacher.jar" \
    "trading-host${host_idx}" \
    --class  "$class" \
    --method "$method" \
    --condition "$condition" \
    --hand-off
}

case "${1:-}" in
  --stop)         _stop;   exit 0 ;;
  --status)       _status; exit 0 ;;
  --debug-replay) shift; _debug_replay "$@"; exit 0 ;;
esac

echo "[playground] building and starting target1, target2..."
docker compose -f "$REPO/docker-compose.yml" up -d --build target1 target2

_wait_for_ssh trading-host1 2221
_wait_for_ssh trading-host2 2222

# Write SSH config first so setup can use it
cat > "$SSH_CONFIG" <<EOF
Host trading-host1
  HostName localhost
  Port 2221
  User deploy
  IdentityFile $SSH_KEY
  StrictHostKeyChecking no
  BatchMode yes
  KexAlgorithms ecdh-sha2-nistp256

Host trading-host2
  HostName localhost
  Port 2222
  User deploy
  IdentityFile $SSH_KEY
  StrictHostKeyChecking no
  BatchMode yes
  KexAlgorithms ecdh-sha2-nistp256
EOF

export E2E_SSH_KEY="$SSH_KEY"
export E2E_SSH_CONFIG="$SSH_CONFIG"
source "$REPO/tests/lib/bbStruct.sh"

echo "[playground] setting up fixture data on targets..."
FIXTURE_DIR="$REPO/tests/e2e/fixtures"
INSTALL_BASE="/opt/trading"
DATE_TAG="20250522"

for shard in shard_1 shard_2; do
  echo "[playground]   $shard → trading-host1"
  bb_create_shard_layout trading-host1 "$INSTALL_BASE" "$shard"
  bb_create_binaries     trading-host1 "$INSTALL_BASE" "$shard"
  bb_create_archive      trading-host1 "$INSTALL_BASE" "$shard" "$DATE_TAG" "$FIXTURE_DIR/$shard"
done

for shard in shard_3 shard_4; do
  echo "[playground]   $shard → trading-host2"
  bb_create_shard_layout trading-host2 "$INSTALL_BASE" "$shard"
  bb_create_binaries     trading-host2 "$INSTALL_BASE" "$shard"
  bb_create_archive      trading-host2 "$INSTALL_BASE" "$shard" "$DATE_TAG" "$FIXTURE_DIR/$shard"
done

echo "[playground] copying replay-stub.jar to targets..."
scp -F "$SSH_CONFIG" "$REPO/tools/replay-stub/replay-stub.jar" trading-host1:/tmp/replay-stub.jar
scp -F "$SSH_CONFIG" "$REPO/tools/replay-stub/replay-stub.jar" trading-host2:/tmp/replay-stub.jar

export SHBANG_SSH_KEY="$SSH_KEY"
export SHBANG_SSH_CONFIG="$SSH_CONFIG"
export HOCON_JAR="$REPO/tools/hocon-to-json/hocon.jar"

# Wire in JAVA_HOME if not already set — needed for HOCON conversion and jdi-attacher
if [[ -z ${JAVA_HOME:-} ]]; then
  for _jh in "/c/d/i/jdk-25.0.3+9" "/usr/lib/jvm/java-17" "/usr/lib/jvm/java-17-openjdk"; do
    [[ -x "${_jh}/bin/java" ]] && { export JAVA_HOME="$_jh"; break; }
  done
  unset _jh
fi
[[ -n ${JAVA_HOME:-} && $PATH != *"${JAVA_HOME}/bin"* ]] && export PATH="${JAVA_HOME}/bin:${PATH}"

echo
echo "[playground] ready. env vars set:"
echo "  SHBANG_SSH_KEY=$SHBANG_SSH_KEY"
echo "  SHBANG_SSH_CONFIG=$SHBANG_SSH_CONFIG"
echo "  HOCON_JAR=$HOCON_JAR"
[[ -n ${JAVA_HOME:-} ]] && echo "  JAVA_HOME=$JAVA_HOME"
echo
echo "  ssh -F $SSH_CONFIG trading-host1"
echo "  ssh -F $SSH_CONFIG trading-host2"
echo
echo "  bin/sh.bang run examples/solace-replay/replay.shbang --ctx examples/solace-replay/environment.json"
echo
echo "[playground] debug-replay (requires JDK on host):"
echo "  bin/playground --debug-replay [shard] [class] [method] [condition]"
echo "  bin/playground --debug-replay shard_1 OrderEventHandler process orderId=ORD-12345"
echo
echo "[playground] tip: 'source bin/playground' to set env vars in your current shell"
echo "             'bin/playground --stop' to tear down"
