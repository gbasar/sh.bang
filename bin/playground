#!/usr/bin/env bash
# Playground entry point.
#
# Usage:
#   source bin/playground          # start containers, install fixtures, set env vars
#   bin/playground --stop          # tear down containers
#   bin/playground --status        # show container state
#   bin/playground --debug-replay [shard] [class] [method] [condition]
#   bin/playground --debug-replay-intellij [shard] [class] [method] [condition]

[[ "${BASH_SOURCE[0]}" != "${0}" ]] || set -euo pipefail

REPO="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

# Ensure java is on PATH for debug commands
if [[ -z ${JAVA_HOME:-} ]]; then
  for _jh in "/c/d/i/jdk-25.0.3+9" "/usr/lib/jvm/java-17" "/usr/lib/jvm/java-17-openjdk"; do
    [[ -x "${_jh}/bin/java" ]] && { export JAVA_HOME="$_jh"; break; }
  done
  unset _jh
fi
[[ -n ${JAVA_HOME:-} && $PATH != *"${JAVA_HOME}/bin"* ]] && export PATH="${JAVA_HOME}/bin:${PATH}"

_stop() {
  echo "[playground] stopping containers..."
  docker compose -f "$REPO/docker-compose.yml" stop target1 target2
  docker compose -f "$REPO/docker-compose.yml" rm -f target1 target2
  rm -f "$REPO/.playground-ssh-config"
  echo "[playground] done."
}

_status() {
  docker compose -f "$REPO/docker-compose.yml" ps target1 target2
}

declare -A _CMDS=(
  [--stop]=_stop
  [--status]=_status
)

arg=${1:-}

fn=${_CMDS[$arg]:-}
if [[ -n $fn ]]; then
  "$fn"
  exit 0
fi

if [[ $arg == --debug-replay || $arg == --debug-replay-intellij ]]; then
  shift
  exec "$REPO/bin/playground-debug" "${arg#--}" "$@"
fi

# Default: full setup (sourceable)
source "$REPO/bin/playground-setup"
