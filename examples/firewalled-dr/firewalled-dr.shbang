// Deploy new version
//   1. Push new version to each 


#! Push new versions

#!  Primary and backup
for_each ${trading.shard[*]}
  | @${primary.host}:${install.directory}/app/${appName}/lib send ${resources.replayJar}
  | @${failvoer.host}:${install.directory}/app/${appName}/lib send ${resources.replayJar}
  #! backup 
| for_each ${dr.host}
  | @${dr.host}:${dr.directory} send ${resources.replayJar}
  | @${dr.host}:${dr.directory} run java -jar replay.jar


# Yuo know what's really cool claude i just realized this is totalldifferent~
#
#! Push new version (remember to do dr first)
#!  Primary and backup
for_each ${trading.shard[*]}
| #! DR first 
| for_each ${dr.host}
| | @${dr.host}:${dr.directory}/app/${appName}/lib send ${resources.replayJar}
| | @${dr.host}:${dr.directory}/app/${appName}/bin restart.sh
|
| #! Primary / Failover 
| #   (now that dr is done thanks to our (depth first  :) )
| @${primary.host}:${install.directory}/app/${appName}/lib send ${resources.replayJar}
| @${failvoer.host}:${install.directory}/app/${appName}/lib send ${resources.replayJar}




#! Send jar and run on primary

for_each ${trading.shard[*]}
| @${primary.host}:${install.directory} send ${resources.replayJar}
| @${primary.host}:${install.directory} run java -jar replay.jar


