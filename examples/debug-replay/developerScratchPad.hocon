# Developer scratch pad — my session config for this investigation.
# In real use this file is gitignored and stays local to each developer.

staging {
  jumphost     = "trading-host1"   # SSH target (resolved via ssh-config-local in playground)
  root         = "/opt/trading"
}

archive {
  date = "20250522"   # date tag of the rdat archive to pull (YYYYMMDD)
}

debug {
  shard        = 1                        # which shard to target (matches trading.shard key)
  class        = "com.bluebird.trading.OrderEventHandler"
  method       = process
  condition    = "orderId=ORD-12345"
  traceFilter  = "com.bluebird.trading.*" # filter to trading package (empty = trace all classes)
  traceLimit   = 500                      # max method events to capture before stopping
  render       = "fields"                 # id | string | fields
  fieldDepth   = 2                        # how deep to recurse into objects
  fieldMax     = 20                       # max fields per object
  maxStringLen = 200                      # truncate long strings
}
