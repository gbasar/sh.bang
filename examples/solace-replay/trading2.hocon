
install {
  directory = /local/1/trading
  user = sysprod
}

logging {
  level = warn
}

runtime {
  javaHome = /usr/bin/java/jdk8
}

// i believe this is provided to the runtime at startup
trading {
  shard = ${trading.instances}

  instances {
    1 {
      primary.host = hostName
      primary.directory = ${install.directory}"/shard_1"
      backup.host = otherHost
      backup.directory = ${install.directory}"/shard_1"
    }
    2 {}
  }
}
