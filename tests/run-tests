#!/usr/bin/env bash
set -euo pipefail

readonly ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
readonly BIN="$ROOT/bin/sh.bang"
readonly FX="$ROOT/tests/fixtures"
readonly EX="$ROOT/examples"
readonly EX1="$ROOT/examples/archive/v1"

# ---------- framework ----------

PASS=0
FAIL=0

pass() { PASS=$(( PASS + 1 )); printf '  [pass] %s\n' "$*"; }
fail() { FAIL=$(( FAIL + 1 )); printf '  [FAIL] %s\n' "$*" >&2; }

assert_eq() {
  local label=$1 got=$2 want=$3
  [[ $got == "$want" ]] && pass "$label" || fail "$label — got: '$got'  want: '$want'"
}

assert_contains() {
  local label=$1 haystack=$2 needle=$3
  [[ $haystack == *"$needle"* ]] && pass "$label" || fail "$label — missing: $needle"
}

assert_not_contains() {
  local label=$1 haystack=$2 needle=$3
  [[ $haystack != *"$needle"* ]] && pass "$label" || fail "$label — should not contain: $needle"
}

assert_fails() {
  local label=$1; shift
  if "$@" >/dev/null 2>&1; then
    fail "$label — expected non-zero exit"
  else
    pass "$label"
  fi
}

assert_stderr() {
  local label=$1 needle=$2; shift 2
  local tmp; tmp=$(mktemp)
  "$@" 2>"$tmp" >/dev/null || true
  local err; err=$(cat "$tmp"); rm -f "$tmp"
  [[ $err == *"$needle"* ]] && pass "$label" || fail "$label — stderr missing: $needle"
}

section() { printf '\n%s\n' "--- $* ---"; }

summary() {
  printf '\n%d passed, %d failed\n' "$PASS" "$FAIL"
  (( FAIL == 0 ))
}

# ---------- version / help ----------

section "version and help"

assert_eq       "--version"              "$("$BIN" --version)"   "0.1.0"
assert_contains "--help has usage"       "$("$BIN" --help)"      "sh.bang --version"
assert_contains "--help has -vvvv"       "$("$BIN" --help)"      $'-vvvv\twire'
assert_contains "-h works"              "$("$BIN" -h)"           "sh.bang --version"

# ---------- error handling ----------

section "error handling"

assert_fails "no args"              "$BIN"
assert_fails "unknown command"      "$BIN" badcmd
assert_fails "run: no playbook"     "$BIN" run
assert_fails "run: no --ctx"        "$BIN" run "$FX/minimal.shbang"
assert_fails "playbook not found"   "$BIN" run /no/such/file        --ctx "$FX/minimal.json"
assert_fails "ctx not found"        "$BIN" run "$FX/minimal.shbang" --ctx /no/such/ctx.json
assert_fails "invalid syntax"       "$BIN" run "$FX/invalid.shbang" --ctx "$FX/minimal.json"
assert_stderr "invalid syntax msg" "cannot parse line 2" \
  "$BIN" run "$FX/invalid.shbang" --ctx "$FX/minimal.json"

# ---------- parser: replay ----------

section "parser — replay"

_replay=$("$BIN" run "$EX1/replay/replay.shbang" --ctx "$EX1/replay/context.json" --dry-run)
assert_contains "for_each selector"  "$_replay" "[for_each] topology.shards[shard3]"
assert_contains "@ subject (scp)"    "$_replay" 'subject=@${host}:'
assert_contains "# subject (ssh)"    "$_replay" 'subject=#${host}:'
assert_contains "send pipe"          "$_replay" 'verb=send args=${resources.replayJar}'
assert_contains "run pipe"           "$_replay" 'verb=run args=${java} -jar replay.jar'

# ---------- parser: canary-deploy ----------

section "parser — canary-deploy"

_canary=$("$BIN" run "$EX1/canary-deploy/canary-deploy.shbang" --ctx "$EX1/canary-deploy/canary-deploy.json" --dry-run)
assert_contains "for_each"           "$_canary" "[for_each] topology.shards[shard3]"
assert_contains "send jar"           "$_canary" "verb=send"
assert_contains "deploy step"        "$_canary" "deploy.jar"
assert_contains "deploy version arg" "$_canary" '--version ${release.version}'
assert_contains "smoke step"         "$_canary" "smoke.jar"
assert_contains "smoke host arg"     "$_canary" '--host ${host}'

# ---------- parser: snapshot ----------

section "parser — snapshot"

_snap=$("$BIN" run "$EX1/snapshot/snapshot.shbang" --ctx "$EX1/snapshot/snapshot.json" --dry-run)
assert_contains "for_each"           "$_snap" "[for_each] topology.shards[shard3]"
assert_contains "# subject: ssh"     "$_snap" 'subject=#${host}:'
assert_contains "@ subject: fetch"   "$_snap" 'subject=@${host}:'
assert_contains "quiesce step"       "$_snap" "quiesce.jar"
assert_contains "tar step"           "$_snap" "verb=run args=tar"
assert_contains "fetch step"         "$_snap" "verb=fetch"
assert_contains "unquiesce step"     "$_snap" "unquiesce.jar"

# ---------- parser: cert-rotate ----------

section "parser — cert-rotate"

_cert=$("$BIN" run "$EX1/cert-rotate/cert-rotate.shbang" --ctx "$EX1/cert-rotate/cert-rotate.json" --dry-run)
assert_contains "for_each wildcard"   "$_cert" "[for_each] topology.shards[*]"
assert_contains "@ subject: send"     "$_cert" 'subject=@${host}:'
assert_contains "# subject: run"      "$_cert" 'subject=#${host}:'
assert_contains "send cert"           "$_cert" 'args=${resources.cert}'
assert_contains "send key"            "$_cert" 'args=${resources.key}'
assert_contains "reload step"         "$_cert" "reload-ssl.jar"
assert_contains "verify step"         "$_cert" "verify-ssl.jar"

# ---------- parser: edge cases ----------

section "parser — edge cases"

_empty=$("$BIN" run "$FX/comments-only.shbang" --ctx "$FX/minimal.json" --dry-run)
assert_eq "comments-only: no output" "$_empty" ""

_multi=$("$BIN" run "$FX/multi-block.shbang" --ctx "$FX/minimal.json" --dry-run)
_fe_count=$(grep -c '\[for_each\]' <<< "$_multi" || true)
assert_eq      "multi-block: two for_each events" "$_fe_count" "2"
assert_contains "multi-block: send pipe"  "$_multi" "verb=send"
assert_contains "multi-block: run pipe"   "$_multi" "verb=run"

# ---------- verbosity ----------

section "verbosity levels"

_v0=$("$BIN"       run "$EX1/replay/replay.shbang" --ctx "$EX1/replay/context.json" --dry-run 2>&1)
_v1=$("$BIN" -v    run "$EX1/replay/replay.shbang" --ctx "$EX1/replay/context.json" --dry-run 2>&1)
_v2=$("$BIN" -vv   run "$EX1/replay/replay.shbang" --ctx "$EX1/replay/context.json" --dry-run 2>&1)
_v3=$("$BIN" -vvv  run "$EX1/replay/replay.shbang" --ctx "$EX1/replay/context.json" --dry-run 2>&1)
_v4=$("$BIN" -vvvv run "$EX1/replay/replay.shbang" --ctx "$EX1/replay/context.json" --dry-run 2>&1)
_vl=$("$BIN" --verbose run "$EX1/replay/replay.shbang" --ctx "$EX1/replay/context.json" --dry-run 2>&1)

assert_not_contains "default: no log lines"  "$_v0" "[sh.bang:"
assert_contains     "-v: info present"       "$_v1" "[sh.bang:info]"
assert_not_contains "-v: debug absent"       "$_v1" "[sh.bang:debug]"
assert_contains     "-vv: debug present"     "$_v2" "[sh.bang:debug]"
assert_not_contains "-vv: trace absent"      "$_v2" "[sh.bang:trace]"
assert_contains     "-vvv: trace present"    "$_v3" "[sh.bang:trace]"
assert_not_contains "-vvv: wire absent"      "$_v3" "[sh.bang:wire]"
assert_contains     "-vvvv: wire present"    "$_v4" "[sh.bang:wire]"
assert_contains     "--verbose = -v: info"   "$_vl" "[sh.bang:info]"
assert_not_contains "--verbose = -v: no debug" "$_vl" "[sh.bang:debug]"

# ---------- execution: dry-run renders variables ----------

section "execution — dry-run renders variables"

_dr=$("$BIN" run "$EX1/cert-rotate/cert-rotate.shbang" --ctx "$EX1/cert-rotate/cert-rotate.json" --dry-run 2>&1)
assert_contains     "cmd:scp lines"      "$_dr" "[cmd:scp]"
assert_contains     "cmd:ssh lines"      "$_dr" "[cmd:ssh]"
assert_contains     "dry-run: scp push"  "$_dr" "[dry-run]"
assert_contains     "dry-run: verb label" "$_dr" "→ scp push"
_dr_cmd=$(grep '^\[cmd:' <<< "$_dr" || true)
assert_not_contains "cmd lines: no raw vars" "$_dr_cmd" '${host}'
assert_contains     "real hostname"      "$_dr" ".prod.internal"

# ---------- execution: HOCON context ----------

section "execution — HOCON context"

if [[ -f ${HOCON_JAR:-/usr/local/lib/hocon.jar} ]]; then
  _hdr=$("$BIN" run "$EX1/cert-rotate/cert-rotate.shbang" \
         --ctx "$EX1/cert-rotate/cert-rotate.hocon" --dry-run 2>&1)
  assert_contains     "hocon: cmd:scp"       "$_hdr" "[cmd:scp]"
  assert_contains     "hocon: real hostname" "$_hdr" ".prod.internal"
  assert_not_contains "hocon: no vars"       "$_hdr" '${host}'
else
  printf '  [skip] HOCON jar not found — set HOCON_JAR or build with HOCON_JAR_URL\n'
fi

# ---------- done ----------

summary
